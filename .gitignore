# =========================
# 📊 Data (DO NOT PUSH RAW)
# =========================
data/raw/
data/processed/
data/models/
data/artifacts/

# Keep ONLY essential feature artifacts (optional override)
# Comment this out if you WANT to track features
data/features/*.parquet
data/features/*.pkl

# =========================
# 📈 Outputs (EXPERIMENTAL)
# =========================
outputs/*.csv
outputs/*.parquet

# Monitoring artifacts
outputs/**/daily_drift_report.json
outputs/**/reference.parquet
outputs/**/current.parquet

# Simulation artifacts
outputs/**/batch_simulation_state.json
outputs/**/batch_stream_log.csv

# Model artifacts
outputs/models/

# =========================
# 📜 Logs
# =========================
logs/
**/logs/
*.log

src/_deprecated/
